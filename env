# =========================================================
# Cognifyz Inventory Pro - Environment Configuration Template
# Copy this file to ".env" and fill in real values.
# NEVER commit your actual .env file to GitHub.
# =========================================================

# The port your Express server will listen on.
# Render/Railway will inject their own PORT automatically in production,
# but this is used as a local fallback.
PORT=5000

# Your MongoDB connection string (MongoDB Atlas recommended for production).
# Example: mongodb+srv://username:password@cluster0.mongodb.net/cognifyzInventory?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/cognifyzInventory

# A long, random, secret string used to sign JSON Web Tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret_string

# How long issued JWTs remain valid.
JWT_EXPIRES_IN=7d

# Node environment: "development" or "production"
NODE_ENV=development
